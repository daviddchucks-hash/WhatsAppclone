rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Profile pictures: any signed-in user can view; only the owner can upload.
    match /profilePictures/{uid}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Group icons: any signed-in user can view; any signed-in user can upload
    // (app-level logic restricts this action to group admins).
    match /groupIcons/{groupId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 10 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');
    }

    // Chat media: images, videos, documents shared inside a chat.
    match /chatMedia/{chatId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 50 * 1024 * 1024;
    }

    // Voice notes recorded in-app.
    match /voiceNotes/{chatId}/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
                   && request.resource.size < 20 * 1024 * 1024
                   && request.resource.contentType.matches('audio/.*');
    }

    // Deny everything else by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
